# Copy to .env and adjust. .env is git-ignored.
DJANGO_SETTINGS_MODULE=config.settings.dev
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Leave blank to use SQLite (default). For PostgreSQL:
# DATABASE_URL=postgres://user:password@localhost:5432/school_saas
DATABASE_URL=

# Frontend origin (Vite dev server)
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Auth cookies (set Secure=True behind HTTPS in production)
AUTH_COOKIE_SECURE=False
AUTH_COOKIE_SAMESITE=Lax
